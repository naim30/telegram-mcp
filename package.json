{
  "name": "telegram-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Telegram as your own USER account (GramJS/MTProto) — send/read/search messages, files, and chats over stdio. Session-based, not a bot.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "telegram-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "login": "node dist/login.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "telegram": "^2.26.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.14"
  }
}
