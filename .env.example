# App credentials from https://my.telegram.org/apps (identify the app, not the
# account). Required for both `npm run login` and the running server.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Portable session for your logged-in USER account. Generate it once with
# `npm run login`, then paste the printed string here. Secret — full account
# access. Leave blank until you've run login.
TELEGRAM_SESSION=

# Optional default chat (@username or numeric id) used when a tool omits `chat`.
TELEGRAM_DEFAULT_CHAT=

# development | production (controls logging verbosity). Defaults to production.
NODE_ENV=
